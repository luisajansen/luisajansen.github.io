@misc{Jansen2025_TensionOpenData,
  title = {On the {{Tension Between Open Data}} and {{Data Protection}} in {{Research}}},
  author = {Jansen, Luisa and Borgert, Nele and Elson, Malte},
  year = 2025,
  month = apr,
  publisher = {PsyArXiv},
  doi = {10.31234/osf.io/5jt3s_v2},
  urldate = {2025-05-26},
  abstract = {The push for Open Science practices, including open data, clashes with the need for strict data protection of participant information. This creates a growing crisis in HCI research. Despite its critical role, data protection remains an afterthought in metascience, leaving researchers without clear guidance and dedicated resources, endangering both participant privacy and scientific openness. We illustrate that Meta-HCI is uniquely positioned to address this challenge by investigating how researchers navigate these tensions and developing strategies that align openness with privacy. We propose starting points for solutions such as minimizing data collection and reusing datasets. This is a call to action---without urgent intervention, both the privacy of research data and Open Science are at risk.},
  copyright = {https://creativecommons.org/licenses/by/4.0/legalcode},
  selected = {true}
}

@misc{Jansen2026_PuttingPrivacyTest,
  title = {Putting {{Privacy}} to the {{Test}}: {{Introducing Red Teaming}} for {{Research Data Anonymization}}},
  author = {Jansen, Luisa and Ulmann, Tim and Jordi, Robine and Elson, Malte},
  year = 2026,
  doi = {10.48550/arXiv.2601.19575},
  html = {https://arxiv.org/abs/2601.19575},
  abstract = {The anonymization of research data is a critical step in protecting participant privacy, yet current practices often lack rigorous evaluation. We introduce a red teaming approach for assessing the effectiveness of research data anonymization, drawing on adversarial testing methodologies from cybersecurity. Our framework provides researchers with a systematic way to identify re-identification risks in anonymized datasets before publication.},
  selected = {true}
}

@inproceedings{Martius2025_OutSightOutb,
  title = {Out of {{Sight}}, {{Out}} of {{Mind}}? {{Exploring Data Protection Practices}} for {{Personal Data}} in {{Usable Security}} \& {{Privacy Studies}}},
  shorttitle = {Out of {{Sight}}, {{Out}} of {{Mind}}?},
  booktitle = {Proceedings of the 2025 {{CHI Conference}} on {{Human Factors}} in {{Computing Systems}}},
  author = {Martius, Florin and Jansen, Luisa and Struck, Lukas and Arumugam, Arthi and Geierhaas, Lisa and Ortloff, Anna-Marie and Smith, Matthew and Tiefenau, Christian},
  year = 2025,
  month = apr,
  pages = {1--16},
  publisher = {ACM},
  address = {Yokohama Japan},
  doi = {10.1145/3706598.3713654},
  urldate = {2026-01-22},
  isbn = {979-8-4007-1394-1},
  langid = {english},
  abstract = {Adherence to data protection measures such as pseudonymization or anonymization is critical in human subjects research because it has a direct impact on the confidentiality of participants’ sensitive information, trust in research practices, and compliance with ethical and legal standards. Regulations such as the General Data Protection Regulation (GDPR) and guarantees made by researchers in informed consent forms mandate strict protocols for data security. However, compliance with these is not always straightforward. To gain qualitative insights into data protection practices in the field of Usable Security and Privacy (USP), we conducted interviews with 22 practitioners (five professors, eight researchers, nine data protection officers) and one focus group with five researchers. Overall, our results show a high awareness of ethical and legal responsibilities but highlight many practical and procedural issues. Based on these, we make concrete recommendations on how to improve the protection of personal data in research.},
  selected = {true}
}
